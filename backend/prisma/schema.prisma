// This is your Prisma schema file
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  role      String    @default("user") // "user" or "admin"
  bookings  Booking[]
}

model Lot {
  id           Int       @id @default(autoincrement())
  name         String
  address      String
  pincode      String
  price_per_hr Float
  is_shaded    Boolean   @default(false)
  spots        Spot[]
}

model Spot {
  id       Int       @id @default(autoincrement())
  lotId    Int
  lot      Lot       @relation(fields: [lotId], references: [id])
  status   String    @default("available") // "available" or "occupied"
  bookings Booking[]
}

model Booking {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  spotId      Int
  spot        Spot      @relation(fields: [spotId], references: [id])
  vehicleNum  String
  startTime   DateTime  @default(now())
  endTime     DateTime?
  totalCost   Float?
  status      String    @default("ongoing") // "ongoing" or "completed"
}